{
  "name": "doit",
  "private": true,
  "version": "0.1.40",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:dmg": "PATH=\"/opt/homebrew/opt/rustup/bin:$HOME/.cargo/bin:$PATH\" tauri build --bundles dmg --ci",
    "version": "node scripts/sync-version.mjs && git add src-tauri/tauri.conf.json src-tauri/Cargo.toml src-tauri/Cargo.lock",
    "release": "node scripts/release.mjs",
    "release:minor": "node scripts/release.mjs --minor",
    "generate-icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@ant-design/happy-work-theme": "^2.0.0",
    "@antdv-next/happy-work-theme": "^1.0.0",
    "@antdv-next/icons": "^1.0.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@fontsource/zcool-xiaowei": "^5.2.8",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "@types/canvas-confetti": "^1.9.0",
    "antdv-next": "^1.3.1",
    "canvas-confetti": "^1.9.4",
    "dayjs": "^1.11.21",
    "jspdf": "^4.2.1",
    "lightningcss": "^1.32.0",
    "sortablejs": "^1.15.7",
    "sql.js": "^1.14.1",
    "vue": "^3.5.34",
    "vue-draggable-plus": "^0.6.1",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-vue": "^6.0.7",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "vite": "^8.0.14",
    "vue-tsc": "^3.3.2"
  }
}
