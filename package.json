{
  "name": "doit",
  "private": true,
  "version": "0.1.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:dmg": "PATH=\"/opt/homebrew/opt/rustup/bin:$HOME/.cargo/bin:$PATH\" tauri build --bundles dmg --ci",
    "version": "node scripts/sync-version.mjs && git add src-tauri/tauri.conf.json src-tauri/Cargo.toml",
    "release": "npm version patch -m \"chore: release v%s\" && npm run version && git push --follow-tags"
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "jspdf": "^4.2.1",
    "lightningcss": "^1.32.0",
    "radix-vue": "^1.9.17",
    "sortablejs": "^1.15.7",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.34",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "vite": "^8.0.14",
    "vue-tsc": "^3.3.2"
  }
}
