{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/main/packages/tauri-config-schema/schema.json",
  "productName": "Doit",
  "version": "0.1.46",
  "identifier": "com.nabaonan.doit",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Doit",
        "width": 640,
        "height": 760,
        "minWidth": 480,
        "minHeight": 500,
        "resizable": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "languages": [
          "SimpChinese",
          "English"
        ]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
